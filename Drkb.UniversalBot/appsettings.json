{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      } 
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "ApplicationName" : "Drkb.UniversalBot"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=CONTROL-DRKB.drbol.ru;Port=5432;Database=Drkb.UniversalBot;Username=postgres;Password=Drkb2014;Trust Server Certificate=True;"
  },
  "JwtSettings" : {
    "Issuer" : "микросервис авторизации ДРКБ",
    "Audience" : "все микросервисы дркб",
    "SecretKey" : "apple happiness wind book journey star ocean dream sun music"
  },
  "Max": {
    "SubscriptionUrl": "https://platform-api.max.ru/subscriptions",
    "AccessToken": "our_token",
    "UpdateTypes": ["message_created", "bot_started", "message_callback"],
    "Secret": "our_secret"
  },
  "AllowedHosts": "*"
}
