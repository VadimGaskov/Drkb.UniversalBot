<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RootNamespace>Drkb.UniversalBot.Contracts</RootNamespace>
        <Version>1.0.0</Version>
        <Authors>Glen</Authors>
        <PackageDescription>Пакет с контрактами бота</PackageDescription>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>

        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <NoWarn>$(NoWarn);1591</NoWarn>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="MessageBroker.Abstractions" Version="2.0.1" />
    </ItemGroup>

</Project>
